# ─────────────────────────────────────────────────────────────
#  Database (PostgreSQL 13+)
#  Copy this file to `.env.local` and fill in your values.
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/energy_optimizer"

# Application
NODE_ENV="development"

# ─────────────────────────────────────────────────────────────
#  Auth — secret to sign session JWTs (use a long random string)
# ─────────────────────────────────────────────────────────────
JWT_SECRET="dev-only-insecure-secret-change-me-in-production"

# ─────────────────────────────────────────────────────────────
#  Hermes agent — vía su proxy OpenAI-compatible:  hermes proxy start
#  La API key vive SOLO acá, en el backend (RNF1). Como el proxy
#  adjunta tus credenciales reales, cualquier bearer token sirve.
#
#  HERMES_MOCK=true → stream simulado (chat sin proxy levantado).
#  HERMES_MOCK=false → usa el proxy real (requiere `hermes proxy start`).
#
#  Modelo: hermes-4 pide créditos; los :free soportan tools.
#  Listar:  curl -s http://127.0.0.1:8645/v1/models -H "Authorization: Bearer x"
# ─────────────────────────────────────────────────────────────
HERMES_API_URL="http://127.0.0.1:8645/v1"
HERMES_API_KEY="local-proxy"
HERMES_MODEL="stepfun/step-3.7-flash:free"
HERMES_MOCK="true"

# ─────────────────────────────────────────────────────────────
#  MCP server (standalone HTTP transport for Hermes)
# ─────────────────────────────────────────────────────────────
MCP_PORT="8000"
