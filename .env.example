# ─────────────────────────────────────────────────────────────
#  Database (PostgreSQL 13+)
#  Copy this file to `.env.local` and fill in your values.
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/energy_optimizer"

# Application
NODE_ENV="development"

# ─────────────────────────────────────────────────────────────
#  Auth — secret to sign session JWTs (use a long random string)
# ─────────────────────────────────────────────────────────────
JWT_SECRET="dev-only-insecure-secret-change-me-in-production"

# ─────────────────────────────────────────────────────────────
#  Hermes agent (OpenAI-compatible gateway)
#  The API key lives ONLY here, on the backend (RNF1).
#  HERMES_MOCK=true returns a deterministic fake stream so the chat
#  works without the gateway running. Set to false to hit the real one.
# ─────────────────────────────────────────────────────────────
HERMES_API_URL="http://localhost:8642/v1"
HERMES_API_KEY=""
HERMES_MODEL="hermes-agent"
HERMES_MOCK="true"

# ─────────────────────────────────────────────────────────────
#  MCP server (standalone HTTP transport for Hermes)
# ─────────────────────────────────────────────────────────────
MCP_PORT="8000"
